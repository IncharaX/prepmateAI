# ===================================
# PrepMate AI - Backend Configuration
# ===================================
# IMPORTANT: Never commit .env file with real credentials to version control

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (MongoDB)
# Get connection string from MongoDB Atlas
MONGODB_URI=
DB_NAME=

# Firebase Admin SDK Configuration
# Download from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Groq AI API (for interview feedback)
# Get from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=

# JWT Configuration (Session Token)
# Generate a strong random string for production: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRY=7d

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Features
ENABLE_ANALYTICS=true
ENABLE_ADMIN_PANEL=true
